# .ssh/config - access Groupon servers via SSH
#
# This version of the .ssh/config file is for people accessing Groupon
# hosts via the Internet. If you have a headless role account, for
# example, for a Capistrano deploy, please use this variant instead:
# https://ssh.groupondev.com/role_config
#
# For more information, see this Groupon internal Wiki page:
# https://wiki.groupondev.com/Remote_access
#
# For questions, comments, or bug reports, please e-mail:
# prod-tools@groupon.com
#
# This file comes from the ssh_config dir in the ops-package-recipes repo:
# git clone git:ops-package-recipes
#
# You can download it from the Internet through your browser:
# https://ssh.groupondev.com/config
Host *
  # UseRoaming no

Host git git.groupon.com
  User git
  ProxyCommand ssh -q b.snc1.groupon.com nc git %p

Host github github.groupon.com github.groupondev.com
  User git
  ProxyCommand ssh -q b.snc1.groupon.com nc github %p

Host *.dub1
  ProxyCommand ssh -q b.dub1.groupon.com nc %h %p

Host *.hkg1
  ProxyCommand ssh -q b.hkg1.groupon.com nc %h %p

Host *.lup1
  ProxyCommand ssh -q b.lup1.groupon.com nc %h %p

Host *.sac1
  ProxyCommand ssh -q b.sac1.groupon.com nc %h %p

Host *.snc1
  ProxyCommand ssh -q b.snc1.groupon.com nc %h %p

Host *.west
  ProxyCommand ssh -q b.west.groupon.com nc %h %p

Host *.west2
  ProxyCommand ssh -q b.west2.groupon.com nc %h %p

Host *.dub1 *.hkg1 *.lup1 *.sac1 *.snc1 *.west *.west2 *.groupondev.com *.groupon.com
  ForwardAgent yes
  StrictHostKeyChecking no
  ServerAliveInterval 120
  User kmuralidharan

Host *
  ForwardAgent yes 
